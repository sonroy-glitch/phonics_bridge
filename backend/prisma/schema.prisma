// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(cuid())
  email String @unique
  password String 
  teacher Boolean @default(false)
  teacher_code String @unique
  time_created DateTime @default(now())
  assessment Assessment[]
  student Student[]
}

model Assessment{
  id String @id @default(cuid())
  accuracy Float?
  fluency Float?
  completeness Float?
  pronunciation Float?
  error String?
  words String? 
  analysis String?
  time_created DateTime @default(now())
  user_id String
  user User @relation(fields: [user_id], references: [id])
}
model AssessmentStudent{
  id String @id @default(cuid())
  accuracy Float?
  fluency Float?
  completeness Float?
  pronunciation Float?
  error String?
  words String? 
  analysis String?
  time_created DateTime @default(now())
  student_id String
  student Student @relation(fields: [student_id], references: [id])
}
model Student{
  id String @id @default(cuid())
  name String
  roll_number String @default("")
  code String
  time_created DateTime @default(now())
  assessment AssessmentStudent[]
  user User @relation(fields:[code],references:[teacher_code])
}



